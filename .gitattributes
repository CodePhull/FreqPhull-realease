# Auto detect text files and perform LF normalization
* text=auto
# Auto-detect text files and normalize line endings to LF in the repository.
# When checking out on Windows, Git converts to CRLF automatically.
* text=auto

# Force these to specific endings regardless of platform:
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.sh    text eol=lf
*.js    text eol=lf
*.py    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.css   text eol=lf

# Binary files — never touch
*.exe   binary
*.png   binary
*.jpg   binary
*.ico   binary
*.pkl   binary
*.wav   binary
*.mp3   binary
*.flac  binary
*.dll   binary