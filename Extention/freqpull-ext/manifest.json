{
  "manifest_version": 3,
  "name": "Freq.Phull",
  "version": "4.3.0",
  "description": "Grab + analyze YouTube tracks via your local Freq.Phull engine. Persistent download queue with duplicate detection and auto-clear. By Cynphull / Hood Knights.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "http://127.0.0.1:47891/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png" },
    "default_title": "Open Freq.Phull"
  },
  "web_accessible_resources": [
    { "resources": ["icons/*"], "matches": ["https://www.youtube.com/*"] }
  ]
}
